import { ConfigService } from '@diamir/nestjs-config'
import { WinstonLogger } from '@diamir/nestjs-logger'
import { CommandFactory } from 'nest-commander'

import { CommandModule } from './command.module'

export async function createApplication(): Promise<void> {
  await CommandFactory.run(CommandModule, new WinstonLogger({ logLevel: ConfigService.get('logLevel') }))
}
