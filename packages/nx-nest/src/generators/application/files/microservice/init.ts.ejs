import { ConfigService } from '@diamir/nestjs-config'
import { WinstonLogger } from '@diamir/nestjs-logger'
import { NestFactory } from '@nestjs/core'
import type { MicroserviceOptions } from '@nestjs/microservices'
import { Transport } from '@nestjs/microservices'

import { MicroserviceModule } from './microservice.module'
<%# MessageQueue import added by generator %>

export async function createApplication (): Promise<void> {
  const app = await NestFactory.createMicroservice<MicroserviceOptions>(MicroserviceModule, {
    logger: new WinstonLogger({ logLevel: ConfigService.get('logLevel') }),
    transport: Transport.RMQ,
    options: {
      ...ConfigService.get('messageQueue'),
      queue: MessageQueue.<%- projectNames.constantName %>
    }
  })

  await app.listen()
}
