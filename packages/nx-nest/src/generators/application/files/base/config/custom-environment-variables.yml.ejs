<% if (isServer) { %>port: API_PORT<% } %>
logLevel: LOG_LEVEL

misc:
  # maintenance module
  lockfile: MAINTENANCE_LOCKFILE
  maintenanceNotification: MAINTENANCE_MESSAGE
<% if (isServer) { %>  # internal module
  internalRoutesEnabled:
    __name: INTERNAL_ROUTES_ENABLED
    __format: json
  lastUpdateFile: LAST_UPDATE_FILE
  changelogFile: CHANGELOG_FILE

cors:
  __name: CORS_OPTIONS
  __format: json

url:
  basePath: BASE_URL
  apiPath: API_BASE_PATH

swagger:
  enabled:
    __name: SWAGGER_ENABLED
    __format: json
  useHttps:
    __name: SWAGGER_USE_HTTPS
    __format: json
  path: SWAGGER_PATH
<% } -%>
