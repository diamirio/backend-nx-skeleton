<% if (isServer) { %>port: 3000<% } %>
logLevel: debug

misc:
  # maintenance module
  lockfile: maintenance.lock
  maintenanceNotification: null
<% if (isServer) { %>  # internal module
  internalRoutesEnabled: true
  lastUpdateFile: .last-update
  changelogFile: CHANGELOG.md

url:
  basePath: http://localhost:3000
  apiPath: ""

swagger:
  enabled: true
  path: /internal/docs
  title: NestJS Skeleton
  description: API
  useHttps: false

cacheLifetime:
  defaultExpiresHeader: false
  defaultLifetime: 0
  expiresHeader: Expires
  cacheControlHeader: Cache-control
<% } -%>
