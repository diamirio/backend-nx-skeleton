import { ConfigService } from '@diamir/nestjs-config'
import { WinstonLogger } from '@diamir/nestjs-logger'
import { NestFactory } from '@nestjs/core'

import { TaskModule } from './task.module'

export async function createApplication(): Promise<void> {
  await NestFactory.createApplicationContext(TaskModule, {
    logger: new WinstonLogger({ logLevel: ConfigService.get('logLevel') })
  })
}
