import { ConfigService } from '@diamir/nestjs-config'
import { MaintenanceMiddleware, MaintenanceModule } from '@diamir/nestjs-maintenance'
import { SetApiInfoHeaderMiddleware, setEnvironmentVariables } from '@diamir/nestjs-process'
import { BadRequestExceptionFilter, GlobalExceptionFilter, InternalModule, RequestProfilerInterceptor } from '@diamir/nestjs-util-restful'
import { MiddlewareConsumer, Module, NestModule, RequestMethod } from '@nestjs/common'
import { APP_FILTER, APP_INTERCEPTOR } from '@nestjs/core'

import * as modules from './modules'

@Module({
  providers: [
    {
      provide: APP_FILTER,
      useClass: GlobalExceptionFilter
    },
    {
      provide: APP_FILTER,
      useClass: BadRequestExceptionFilter
    },
    {
      provide: APP_INTERCEPTOR,
      useClass: RequestProfilerInterceptor
    }
  ],
  imports: [
    InternalModule.forRoot({
      ...ConfigService.get('misc'),
      enabled: ConfigService.get('misc.internalRoutesEnabled')
    }),
    MaintenanceModule.forRoot({
      application: ConfigService.get('url.basePath'),
      lockfilePath: ConfigService.get('misc.lockfile')
    }),
    ...Object.values(modules)
  ]
})
export class ServerModule implements NestModule {
  async configure (consumer: MiddlewareConsumer): Promise<void> {
    await setEnvironmentVariables()

    consumer
      .apply(MaintenanceMiddleware, SetApiInfoHeaderMiddleware)
      .forRoutes({ path: '*path', method: RequestMethod.ALL })
  }
}
