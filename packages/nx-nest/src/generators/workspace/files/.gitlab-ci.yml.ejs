---
include:
  # https://gitlab.diamir.tech/components/node/-/tree/main
  - component: $CI_SERVER_FQDN/components/node/pipe@1
    inputs:
      node-version: <%= NODE_VERSION %>
  # https://gitlab.diamir.tech/bdsm/gitlab-pipes/-/blob/main/templates/v2/docker-build-internal.gitlab-ci.yml
  - project: bdsm/gitlab-pipes
    file: /templates/v2/docker-build-internal.gitlab-ci.yml
    ref: next

stages:
  - prepare
  - test
  - build
  - docker

workflow:
  rules:
    # do not run on merge-request, just branch pipelines
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
      when: never
    # run if branch or tag is pushed/created
    - if: $CI_COMMIT_BRANCH
    - if: $CI_COMMIT_TAG

build:
  rules:
  -  if: $CI_COMMIT_BRANCH == "develop" || $CI_COMMIT_BRANCH == "main" || $CI_COMMIT_TAG

typecheck:
  extends: .npm-run
  stage: test
  variables:
    NPM_RUN_SCRIPT: build:typecheck
  rules:
    - if: $CI_COMMIT_BRANCH == "develop" || $CI_COMMIT_BRANCH == "main" || $CI_COMMIT_TAG
      when: never
    - when: on_success

