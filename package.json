{
  "name": "@diamir/nx-skeleton",
  "private": true,
  "scripts": {
    "nx": "nx",
    "build": "nx run-many --target build",
    "build:one": "nx build",
    "build:nocache": "nx run-many --target build --skip-nx-cache",
    "manifest:update": "nx run-many --target updateManifest",
    "test": "nx run-many --target test --parallel 10",
    "test:one": "nx test --project",
    "test:e2e": "nx run-many --target test -c e2e --parallel 10",
    "test:e2e:one": "nx test -c e2e --project",
    "test:cov": "nx run-many --target test -c cov --parallel 10",
    "test:cov:one": "nx test -c cov --project",
    "lint": "biome check",
    "lint:check": "nx run-many --parallel 10 --target lint",
    "lint:fix": "nx run-many --parallel 10 --target lint -c fix",
    "update": "nx migrate latest",
    "version:beta": "nx release --skip-publish --preid=beta",
    "version": "nx release --skip-publish",
    "publish:beta": "nx affected --base beta -t build && nx release publish",
    "publish": "nx affected --base master -t build && nx release publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.3",
    "@nestjs/testing": "11.1.8",
    "@nx/devkit": "21.5.3",
    "@nx/jest": "21.5.3",
    "@nx/js": "21.5.3",
    "@nx/plugin": "21.5.3",
    "@nx/workspace": "21.5.3",
    "@pnpm/exportable-manifest": "1000.1.3",
    "@pnpm/read-project-manifest": "1001.1.0",
    "@pnpm/workspace.read-manifest": "1000.2.2",
    "@swc-node/register": "1.9.2",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.5.29",
    "@swc/helpers": "0.5.17",
    "@types/jest": "30.0.0",
    "@types/node": "22.17.0",
    "jest": "30.0.5",
    "jest-environment-node": "29.7.0",
    "lint-staged": "13.3.0",
    "nx": "21.5.3",
    "simple-git-hooks": "2.13.1",
    "ts-jest": "29.4.0",
    "tslib": "2.8.1",
    "typescript": "5.9.2",
    "yaml": "2.8.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npm exec lint-staged"
  },
  "volta": {
    "node": "22.16.0"
  }
}
